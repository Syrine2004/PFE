# ============================================================================
# .env.example - Configuration Template for ResidanatTN
# ============================================================================
# Copy this file to .env and fill in your actual values
# IMPORTANT: Do NOT commit .env to git - it contains sensitive data

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL Auth Service
DB_AUTH_HOST=postgres-auth
DB_AUTH_PORT=5432
DB_AUTH_NAME=residanat_auth
DB_AUTH_USER=postgres
DB_AUTH_PASSWORD=your_secure_password_here

# PostgreSQL Concours Service
DB_CONCOURS_HOST=postgres-concours
DB_CONCOURS_PORT=5432
DB_CONCOURS_NAME=residanat_concours
DB_CONCOURS_USER=postgres
DB_CONCOURS_PASSWORD=your_secure_password_here

# PostgreSQL Dossier Service
DB_DOSSIER_HOST=postgres-dossier
DB_DOSSIER_PORT=5432
DB_DOSSIER_NAME=residanat_dossier
DB_DOSSIER_USER=postgres
DB_DOSSIER_PASSWORD=your_secure_password_here

# ============================================================================
# MESSAGE BROKER (RabbitMQ)
# ============================================================================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ============================================================================
# MICROSERVICES PORTS
# ============================================================================
# Gateway Service
GATEWAY_PORT=8080

# Auth Service
AUTH_SERVICE_PORT=8081

# Concours Service
CONCOURS_SERVICE_PORT=8082

# Dossier Service
DOSSIER_SERVICE_PORT=8084

# IA Validation Service
IA_SERVICE_PORT=8085

# Config Service
CONFIG_SERVICE_PORT=8888

# Discovery Service (Eureka)
DISCOVERY_SERVICE_PORT=8761
EUREKA_URL=http://discovery-service:8761

# ============================================================================
# JWT & SECURITY
# ============================================================================
JWT_SECRET=your_long_secret_key_here_minimum_32_characters
JWT_EXPIRATION=86400000

# ============================================================================
# FRONTEND (Angular)
# ============================================================================
FRONTEND_PORT=4200
API_BASE_URL=http://localhost:8080

# ============================================================================
# IA VALIDATION SERVICE
# ============================================================================
# Python & ML Models
IA_MODELS_PATH=/models
IA_CONFIDENCE_THRESHOLD=0.85

# ============================================================================
# FILE UPLOADS
# ============================================================================
UPLOAD_DIR=/uploads
MAX_FILE_SIZE=10485760

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE_PATH=/logs

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=development
# ENVIRONMENT=production
